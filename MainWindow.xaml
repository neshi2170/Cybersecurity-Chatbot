п»ҝ<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="рҹӣЎпёҸ Cybersecurity Awareness Chatbot" 
        Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- ASCII Art -->
        <Border Grid.Row="0" Background="#16213E" CornerRadius="10" Margin="5" Padding="10">
            <StackPanel>
                <TextBlock x:Name="AsciiArt" 
                           Text="
    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— 
   в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
   в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ
   в–Ҳв–Ҳв•‘       в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—
   в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘
    в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ" 
                           FontFamily="Consolas" 
                           FontSize="10" 
                           Foreground="#00FFAA"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>
                <TextBlock Text="рҹӣЎпёҸ CYBERSECURITY AWARENESS CHATBOT рҹӨ–" 
                           FontSize="14" 
                           FontWeight="Bold"
                           Foreground="#00FFAA"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Image Display -->
        <Border Grid.Row="1" Background="#16213E" CornerRadius="10" Margin="5" Padding="10" Height="120">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#0F3460" CornerRadius="50" Width="60" Height="60" Margin="10">
                    <TextBlock Text="рҹӣЎпёҸ" FontSize="40" TextAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="STAY SAFE ONLINE" 
                               FontSize="18" 
                               Foreground="#00FFAA" 
                               FontWeight="Bold"/>
                    <TextBlock Text="Cybersecurity Awareness Tips" 
                               FontSize="12" 
                               Foreground="#888"/>
                </StackPanel>
                <Border Background="#0F3460" CornerRadius="50" Width="60" Height="60" Margin="10">
                    <TextBlock Text="рҹ”җ" FontSize="40" TextAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>
        
        <!-- Current Topic Display -->
        <Border Grid.Row="2" Background="#16213E" CornerRadius="5" Margin="5" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="рҹ“Ң Current Topic: " Foreground="#888" FontSize="12"/>
                <TextBlock x:Name="CurrentTopicText" Text="Ready to help" Foreground="#00FFAA" FontSize="12" FontWeight="Bold"/>
                <TextBlock Text=" | рҹ’ҫ Memory: " Foreground="#888" FontSize="12" Margin="20,0,0,0"/>
                <TextBlock x:Name="MemoryStatus" Text="Active" Foreground="#00FFAA" FontSize="12"/>
            </StackPanel>
        </Border>
        
        <!-- Chat Display Area -->
        <ListBox x:Name="ChatListBox" 
                 Grid.Row="3" 
                 Margin="5" 
                 Background="#0F3460" 
                 BorderBrush="#00FFAA" 
                 BorderThickness="2"
                 FontFamily="Segoe UI"
                 FontSize="14"
                 Foreground="White"/>
        
        <!-- Input Area -->
        <Grid Grid.Row="4" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="UserInputTextBox" 
                     Grid.Column="0"
                     Background="#0F3460" 
                     Foreground="White"
                     BorderBrush="#00FFAA"
                     BorderThickness="1"
                     FontSize="14"
                     Padding="10"
                     KeyDown="UserInputTextBox_KeyDown"/>
            
            <Button x:Name="SendButton" 
                    Grid.Column="1"
                    Content="рҹ“Ө Send" 
                    Background="#00FFAA"
                    Foreground="#1A1A2E"
                    FontWeight="Bold"
                    Width="80"
                    Margin="5,0,5,0"
                    Click="SendButton_Click"/>
            
            <Button x:Name="VoiceButton" 
                    Grid.Column="2"
                    Content="рҹҺӨ Voice" 
                    Background="#E94560"
                    Foreground="White"
                    FontWeight="Bold"
                    Width="80"
                    Click="VoiceButton_Click"/>
        </Grid>
        
        <!-- Status Bar -->
        <Border Grid.Row="5" Background="#16213E" CornerRadius="5" Margin="5" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="UserNameDisplay" Text="Not logged in" Foreground="#888" FontSize="11"/>
                <TextBlock Text=" | " Foreground="#888" FontSize="11"/>
                <TextBlock Text="рҹ”‘ Try: passwords, scams, privacy, phishing, malware, 2FA, VPN, firewall" Foreground="#00FFAA" FontSize="10"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>